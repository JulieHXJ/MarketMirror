{
  "name": "nightshift",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test --ignore-pattern=evaluate-website",
    "test:ui": "playwright test --ui --ignore-pattern=evaluate-website",
    "test:headed": "playwright test --headed --ignore-pattern=evaluate-website",
    "test:evaluate": "playwright test tests/evaluate-website.spec.ts --project=chromium",
    "evaluate": "TARGET_URL=${TARGET_URL:-https://www.kmw-technology.de/hebammen} npm run test:evaluate",
    "docker:build": "docker build -t nightshift .",
    "docker:run": "docker run -p 3000:3000 nightshift",
    "docker:test": "docker compose --profile test run playwright"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@google/generative-ai": "^0.24.1",
    "@types/express": "^5.0.6",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "next": "^15.1.0",
    "openai": "^6.32.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/forms": "^0.5.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
